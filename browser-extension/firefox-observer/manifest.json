{
  "manifest_version": 2,
  "name": "Quackdas Online Observation",
  "version": "0.7.2",
  "description": "Capture annotated web observation entries and send them to a running Quackdas app.",
  "icons": {
    "48": "assets/icons/icon-48.jpg",
    "96": "assets/icons/icon-96.jpg"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "http://127.0.0.1:45823/*"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "sidebar_action": {
    "default_title": "Quackdas",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "assets/icons/icon-16.jpg",
      "32": "assets/icons/icon-32.jpg",
      "48": "assets/icons/icon-48.jpg"
    }
  },
  "options_ui": {
    "page": "settings.html",
    "browser_style": false,
    "open_in_tab": true
  },
  "commands": {
    "capture-region": {
      "suggested_key": {
        "default": "Alt+Shift+R"
      },
      "description": "Capture observation region"
    },
    "new-note": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "Create new observation note"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quackdas-observer@staffanedling.se",
      "data_collection_permissions": {
        "required": [
          "websiteActivity",
          "websiteContent"
        ]
      }
    }
  },
  "web_accessible_resources": [
    "capture-overlay.css"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self'"
}
